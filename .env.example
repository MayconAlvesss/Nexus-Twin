# ============================================================
# NexusTwin — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# API key that every client must send in the X-NexusTwin-API-Key header.
# Generate a strong random string for production.
NEXUS_API_KEY=nexus-dev-key-change-me

# SHI alert threshold — elements whose health index drops below this
# value will be flagged as WARNING in the API response.
NEXUS_HEALTH_WARNING_THRESHOLD=65

# SHI critical threshold — below this value, severity becomes CRITICAL.
NEXUS_HEALTH_CRITICAL_THRESHOLD=40

# Allowed CORS origins (comma-separated, no trailing slashes).
NEXUS_ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000,http://localhost:8080

# Path to the SQLite database file (relative to the project root).
NEXUS_DB_PATH=nexustwin.db

# Logging level: DEBUG | INFO | WARNING | ERROR
NEXUS_LOG_LEVEL=INFO
